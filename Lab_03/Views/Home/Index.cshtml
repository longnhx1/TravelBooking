@{
    ViewData["Title"] = "Trang chủ";
}

<!-- =========== HERO =========== -->
<section class="hero" aria-label="Banner khuyến mãi">
    <div class="hero__content">
        <span class="hero__tag">
            <i class="fa-solid fa-bolt" aria-hidden="true"></i> Ưu đãi Hè 2025
        </span>
        <h1 class="hero__title">Khám phá Việt Nam cùng chúng tôi</h1>
        <p class="hero__subtitle">
            Khách sạn, tour và vé máy bay – chọn chuyến đi phù hợp chỉ trong vài phút.
            Hành trình tuyệt vời của bạn bắt đầu từ đây.
        </p>

        <!-- Quick search widget -->
        <div class="hero__search-widget">
            <div class="hero__search-tabs">
                <button class="hero__search-tab is-active" data-tab="tour">
                    <i class="fa-solid fa-map-location-dot"></i> Tour
                </button>
                <button class="hero__search-tab" data-tab="hotel">
                    <i class="fa-solid fa-hotel"></i> Khách sạn
                </button>
                <button class="hero__search-tab" data-tab="flight">
                    <i class="fa-solid fa-plane"></i> Vé máy bay
                </button>
            </div>
            <div class="hero__search-form">
                <div class="hero__search-field">
                    <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
                    <input type="text" placeholder="Điểm đến (VD: Đà Nẵng, Sapa...)" id="heroDestination" autocomplete="off" />
                </div>
                <div class="hero__search-field">
                    <i class="fa-solid fa-calendar" aria-hidden="true"></i>
                    <input type="date" id="heroCheckIn" />
                </div>
                <div class="hero__search-field">
                    <i class="fa-solid fa-users" aria-hidden="true"></i>
                    <input type="number" min="1" max="20" value="2" id="heroGuests" />
                    <span class="hero__search-field-label">khách</span>
                </div>
                <a href="/Home/Booking" class="btn btn--primary hero__search-btn">
                    <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i> Tìm kiếm
                </a>
            </div>
        </div>

        <!-- Trust badges -->
        <div class="hero__trust">
            <span><i class="fa-solid fa-shield-halved"></i> Thanh toán an toàn</span>
            <span><i class="fa-solid fa-headset"></i> Hỗ trợ 24/7</span>
            <span><i class="fa-solid fa-tag"></i> Giá tốt nhất</span>
        </div>
    </div>

    <div class="hero__visual" aria-hidden="true">
        <div class="hero__phone-mockup">
            <img src="~/images/hero-travel-banner.webp"
                 alt="Du lịch 2025"
                 loading="eager"
                 onerror="this.src='https://images.unsplash.com/photo-1436491865332-7a61a109cc05?q=80&w=600&auto=format&fit=crop'" />
        </div>
        <!-- Floating stat cards -->
        <div class="hero__stat hero__stat--top">
            <i class="fa-solid fa-star" style="color:#f5a623;"></i>
            <div>
                <strong>4.9/5</strong>
                <span>12.000+ đánh giá</span>
            </div>
        </div>
        <div class="hero__stat hero__stat--bottom">
            <i class="fa-solid fa-suitcase-rolling" style="color:#0071e3;"></i>
            <div>
                <strong>50.000+</strong>
                <span>Khách đặt tour</span>
            </div>
        </div>
    </div>
</section>

