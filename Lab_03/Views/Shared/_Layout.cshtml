<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Travel Booking – Đặt phòng khách sạn, tour và vé máy bay nhanh chóng, tiện lợi." />
    <title>@ViewData["Title"] – Travel Booking</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
</head>
<body>

    <!-- =========== NAVBAR =========== -->
    <header class="navbar" id="mainNavbar">
        <div class="navbar__inner">

            <!-- Logo -->
            <a href="/" class="navbar__logo" aria-label="Trang chủ Travel Booking">
                <i class="fa-solid fa-paper-plane navbar__logo-icon" aria-hidden="true"></i>
                <span class="navbar__logo-text">TravelBooking</span>
            </a>

            <!-- Category menu -->
            <nav class="navbar__menu" aria-label="Danh mục dịch vụ">
                <ul class="navbar__menu-list">
                    <li>
                        <a href="/Home/Booking" class="navbar__menu-link">
                            <i class="fa-solid fa-map-location-dot" aria-hidden="true"></i> Tour
                        </a>
                    </li>
                    <li>
                        <a href="/Home/Booking" class="navbar__menu-link">
                            <i class="fa-solid fa-hotel" aria-hidden="true"></i> Khách sạn
                        </a>
                    </li>
                    <li>
                        <a href="/Home/Booking" class="navbar__menu-link">
                            <i class="fa-solid fa-plane" aria-hidden="true"></i> Vé máy bay
                        </a>
                    </li>
                    <li>
                        <a href="/Home/Booking" class="navbar__menu-link navbar__menu-link--hot">
                            <i class="fa-solid fa-fire" aria-hidden="true"></i> Deal Hot
                        </a>
                    </li>
                </ul>
            </nav>

            <!-- Search bar -->
            <div class="navbar__search">
                <label for="searchInput" class="sr-only">Tìm kiếm chuyến đi</label>
                <i class="fa-solid fa-magnifying-glass navbar__search-icon" aria-hidden="true"></i>
                <input type="search"
                       id="searchInput"
                       class="navbar__search-input"
                       placeholder="Bạn muốn đi đâu?"
                       autocomplete="off" />
            </div>

            <!-- Actions: Booking + Auth -->
            <div class="navbar__actions">
                <a href="/Home/Booking" class="navbar__action-btn" aria-label="Danh sách đặt chỗ">
                    <i class="fa-solid fa-calendar-check" aria-hidden="true"></i>
                    <span>Đặt chỗ</span>
                    <span class="navbar__cart-badge" id="bookingBadge" aria-live="polite" style="display:none;">0</span>
                </a>
                <partial name="_LoginPartial" />
            </div>

            <!-- Mobile hamburger -->
            <button class="navbar__hamburger" id="hamburgerBtn" aria-label="Mở menu" aria-expanded="false">
                <span></span><span></span><span></span>
            </button>

        </div>

        <!-- Mobile menu drawer -->
        <div class="navbar__mobile-menu" id="mobileMenu" aria-hidden="true">
            <ul>
                <li><a href="/Home/Booking"><i class="fa-solid fa-map-location-dot"></i> Tour du lịch</a></li>
                <li><a href="/Home/Booking"><i class="fa-solid fa-hotel"></i> Khách sạn</a></li>
                <li><a href="/Home/Booking"><i class="fa-solid fa-plane"></i> Vé máy bay</a></li>
                <li><a href="/Home/Booking"><i class="fa-solid fa-fire"></i> Deal Hot</a></li>
                <li class="mobile-divider"></li>
                <li><a href="/Home/Booking"><i class="fa-solid fa-calendar-check"></i> Đặt chỗ của tôi</a></li>
                <li><a href="/account/login"><i class="fa-regular fa-circle-user"></i> Đăng nhập</a></li>
            </ul>
        </div>
    </header>

    <!-- =========== MAIN CONTENT =========== -->
    <main id="main-content">
        @RenderBody()
    </main>

    <!-- =========== FOOTER =========== -->
    <footer class="footer">
        <div class="footer__inner">

            <!-- Column 1: Company info -->
            <div class="footer__col">
                <div class="footer__brand">
                    <i class="fa-solid fa-paper-plane footer__brand-icon" aria-hidden="true"></i>
                    <span class="footer__brand-name">TravelBooking</span>
                </div>
                <p class="footer__text">
                    Nền tảng đặt chỗ du lịch tiện lợi hàng đầu Việt Nam: khách sạn, tour và vé máy bay.
                    Cam kết giá tốt nhất, hỗ trợ 24/7 trước và sau chuyến đi.
                </p>
                <div class="footer__socials">
                    <a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#" aria-label="YouTube"><i class="fa-brands fa-youtube"></i></a>
                    <a href="#" aria-label="TikTok"><i class="fa-brands fa-tiktok"></i></a>
                    <a href="#" aria-label="Zalo"><i class="fa-solid fa-comment-dots"></i></a>
                </div>
            </div>

            <!-- Column 2: Services -->
            <div class="footer__col">
                <h3 class="footer__heading">Dịch vụ</h3>
                <ul class="footer__links">
                    <li><a href="/Home/Booking"><i class="fa-solid fa-map-location-dot"></i> Tour trong nước</a></li>
                    <li><a href="/Home/Booking"><i class="fa-solid fa-globe"></i> Tour nước ngoài</a></li>
                    <li><a href="/Home/Booking"><i class="fa-solid fa-hotel"></i> Đặt khách sạn</a></li>
                    <li><a href="/Home/Booking"><i class="fa-solid fa-plane"></i> Vé máy bay</a></li>
                    <li><a href="/Home/Booking"><i class="fa-solid fa-car"></i> Thuê xe du lịch</a></li>
                </ul>
            </div>

            <!-- Column 3: Support -->
            <div class="footer__col">
                <h3 class="footer__heading">Hỗ trợ</h3>
                <ul class="footer__links">
                    <li><a href="#"><i class="fa-solid fa-circle-question"></i> Hướng dẫn đặt tour</a></li>
                    <li><a href="#"><i class="fa-solid fa-credit-card"></i> Phương thức thanh toán</a></li>
                    <li><a href="#"><i class="fa-solid fa-magnifying-glass"></i> Tra cứu đơn hàng</a></li>
                    <li><a href="#"><i class="fa-solid fa-rotate-left"></i> Chính sách hoàn huỷ</a></li>
                    <li><a href="#"><i class="fa-solid fa-comments"></i> FAQ</a></li>
                </ul>
            </div>

            <!-- Column 4: Contact -->
            <div class="footer__col">
                <h3 class="footer__heading">Liên hệ</h3>
                <ul class="footer__contact">
                    <li>
                        <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
                        <span>123 Nguyễn Huệ, Quận 1, TP. Hồ Chí Minh</span>
                    </li>
                    <li>
                        <i class="fa-solid fa-phone" aria-hidden="true"></i>
                        <a href="tel:19001234">1900 1234</a>
                    </li>
                    <li>
                        <i class="fa-solid fa-envelope" aria-hidden="true"></i>
                        <a href="mailto:support@travelbooking.vn">support&#64;travelbooking.vn</a>
                    </li>
                    <li>
                        <i class="fa-solid fa-clock" aria-hidden="true"></i>
                        <span>Hỗ trợ 24/7 mỗi ngày</span>
                    </li>
                </ul>
                <!-- App download badges -->
                <div class="footer__apps">
                    <a href="#" class="footer__app-btn" aria-label="Tải App Store">
                        <i class="fa-brands fa-apple"></i> App Store
                    </a>
                    <a href="#" class="footer__app-btn" aria-label="Tải Google Play">
                        <i class="fa-brands fa-google-play"></i> Google Play
                    </a>
                </div>
            </div>

        </div>

        <div class="footer__bottom">
            <p>© @DateTime.Now.Year Travel Booking. Tất cả quyền được bảo lưu.</p>
            <p>Giấy phép kinh doanh số: 0123456789 – Sở KH&amp;ĐT TP. HCM</p>
        </div>
    </footer>

    <!-- =========== TOAST =========== -->
    <div class="toast" id="cartToast" role="alert" aria-live="polite" aria-atomic="true">
        <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
        <span id="cartToastMsg">Đã thêm chuyến đi vào danh sách đặt chỗ!</span>
    </div>

    <script src="~/js/home.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
