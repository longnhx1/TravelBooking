@model Lab_03.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Chỉnh sửa Tour";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/product/admin-product-form.css" asp-append-version="true" />
}

<div class="product-form-page">
    <form asp-area="Admin" asp-action="Update" method="post" enctype="multipart/form-data" id="editProductForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <!-- Page Header -->
        <header class="product-form-header">
            <div class="product-form-header__left">
                <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="product-form-header__back" title="Quay lại">
                    <i class="fa-solid fa-arrow-left"></i>
                </a>
                <div class="product-form-header__title">
                    <h1>Chỉnh sửa Tour</h1>
                    <p>Đang cập nhật: <strong>@Model.Name</strong></p>
                </div>
            </div>
            <div class="product-form-header__actions">
                <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn-secondary">
                    <i class="fa-solid fa-xmark"></i>
                    <span>Hủy</span>
                </a>
                <button type="submit" class="btn-primary">
                    <i class="fa-solid fa-check"></i>
                    <span>Lưu thay đổi</span>
                </button>
            </div>
        </header>

        <!-- Form Grid -->
        <div class="product-form__grid">

            <!-- ===== LEFT / MAIN COLUMN ===== -->
            <div class="product-form__main">

                <!-- Card: Thông tin Tour -->
                <div class="form-card">
                    <div class="form-card__header">
                        <i class="fa-solid fa-map-location-dot"></i>
                        <h2>Thông tin Tour</h2>
                    </div>
                    <div class="form-card__body">

                        <div class="form-group">
                            <label asp-for="Name" class="form-label">
                                Tên Tour <span class="required">*</span>
                            </label>
                            <input asp-for="Name" class="form-input" placeholder="VD: Tour Đà Lạt Mộng Mơ 3N2Đ..." />
                            <span asp-validation-for="Name" class="form-error"></span>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="Price" class="form-label">
                                    Giá Tour / Người <span class="required">*</span>
                                </label>
                                <div class="input-with-suffix">
                                    <input asp-for="Price" class="form-input" placeholder="0" />
                                    <span class="input-suffix">₫</span>
                                </div>
                                <span asp-validation-for="Price" class="form-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="CategoryId" class="form-label">
                                    Điểm đến (Danh mục) <span class="required">*</span>
                                </label>
                                <div class="select-wrapper">
                                    <select asp-for="CategoryId" asp-items="@ViewBag.Categories" class="form-select">
                                        <option value="">-- Chọn điểm đến --</option>
                                    </select>
                                    <i class="fa-solid fa-chevron-down select-icon"></i>
                                </div>
                                <span asp-validation-for="CategoryId" class="form-error"></span>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="Duration" class="form-label">Thời gian Tour</label>
                                <input asp-for="Duration" class="form-input" placeholder="VD: 3 Ngày 2 Đêm" />
                                <span asp-validation-for="Duration" class="form-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="DepartureLocation" class="form-label">Nơi khởi hành</label>
                                <input asp-for="DepartureLocation" class="form-input" placeholder="VD: TP. Hồ Chí Minh" />
                                <span asp-validation-for="DepartureLocation" class="form-error"></span>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="DepartureDate" class="form-label">Ngày khởi hành</label>
                                <input asp-for="DepartureDate" type="datetime-local" class="form-input" />
                                <span asp-validation-for="DepartureDate" class="form-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="AvailableSeats" class="form-label">Số chỗ trống</label>
                                <input asp-for="AvailableSeats" type="number" class="form-input" placeholder="VD: 20" min="0" max="500" />
                                <span asp-validation-for="AvailableSeats" class="form-error"></span>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Card: Lịch trình & Mô tả -->
                <div class="form-card">
                    <div class="form-card__header">
                        <i class="fa-solid fa-align-left"></i>
                        <h2>Lịch trình & Mô tả</h2>
                    </div>
                    <div class="form-card__body">
                        <div class="form-group">
                            <label asp-for="Description" class="form-label">Lịch trình chi tiết</label>
                            <textarea asp-for="Description" class="form-textarea" rows="8"
                                      placeholder="Mô tả chi tiết lịch trình từng ngày, điểm tham quan, dịch vụ bao gồm..."></textarea>
                            <span asp-validation-for="Description" class="form-error"></span>
                            <div class="form-hint">
                                <i class="fa-solid fa-circle-info"></i>
                                <span>Lịch trình chi tiết giúp khách hàng dễ dàng quyết định đặt tour</span>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- ===== RIGHT / SIDEBAR COLUMN ===== -->
            <div class="product-form__sidebar">

                <!-- Card: Ảnh Tour -->
                <div class="form-card">
                    <div class="form-card__header">
                        <i class="fa-solid fa-image"></i>
                        <h2>Ảnh đại diện Tour</h2>
                    </div>
                    <div class="form-card__body">
                        <div class="image-upload" id="imageUploadArea">
                            <input type="file" name="ImageUrl" class="image-upload__input" id="imageInput" accept="image/*" />

                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <!-- Có ảnh sẵn: hiện preview -->
                                <div class="image-upload__preview" id="imagePreview">
                                    <img src="@Model.ImageUrl" alt="@Model.Name" id="previewImage" />
                                    <div class="image-upload__overlay">
                                        <button type="button" class="image-upload__remove" id="removeImageBtn">
                                            <i class="fa-solid fa-trash"></i>
                                            Xóa
                                        </button>
                                        <label for="imageInput" class="image-upload__change">
                                            <i class="fa-solid fa-rotate"></i>
                                            Đổi ảnh
                                        </label>
                                    </div>
                                </div>
                                <div class="image-upload__placeholder d-none" id="uploadPlaceholder">
                                    <div class="image-upload__icon">
                                        <i class="fa-solid fa-cloud-arrow-up"></i>
                                    </div>
                                    <p class="image-upload__text">Kéo thả ảnh vào đây hoặc</p>
                                    <label for="imageInput" class="image-upload__btn">
                                        <i class="fa-solid fa-folder-open"></i>
                                        Chọn từ máy tính
                                    </label>
                                    <p class="image-upload__hint">PNG, JPG, WEBP (Tối đa 5MB)</p>
                                </div>
                            }
                            else
                            {
                                <!-- Chưa có ảnh: hiện placeholder -->
                                <div class="image-upload__placeholder" id="uploadPlaceholder">
                                    <div class="image-upload__icon">
                                        <i class="fa-solid fa-cloud-arrow-up"></i>
                                    </div>
                                    <p class="image-upload__text">Kéo thả ảnh vào đây hoặc</p>
                                    <label for="imageInput" class="image-upload__btn">
                                        <i class="fa-solid fa-folder-open"></i>
                                        Chọn từ máy tính
                                    </label>
                                    <p class="image-upload__hint">PNG, JPG, WEBP (Tối đa 5MB)</p>
                                </div>
                                <div class="image-upload__preview d-none" id="imagePreview">
                                    <img src="" alt="Preview" id="previewImage" />
                                    <div class="image-upload__overlay">
                                        <button type="button" class="image-upload__remove" id="removeImageBtn">
                                            <i class="fa-solid fa-trash"></i>
                                            Xóa
                                        </button>
                                        <label for="imageInput" class="image-upload__change">
                                            <i class="fa-solid fa-rotate"></i>
                                            Đổi ảnh
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                        <input type="hidden" name="existingImageUrl" value="@Model.ImageUrl" />
                    </div>
                </div>

                <!-- Card: Lưu ý -->
                <div class="form-card form-card--tips">
                    <div class="form-card__header">
                        <i class="fa-solid fa-lightbulb"></i>
                        <h2>Lưu ý khi chỉnh sửa</h2>
                    </div>
                    <div class="form-card__body">
                        <ul class="tips-list">
                            <li>
                                <i class="fa-solid fa-check"></i>
                                <span>Kiểm tra kỹ ngày khởi hành trước khi lưu</span>
                            </li>
                            <li>
                                <i class="fa-solid fa-check"></i>
                                <span>Chỉ upload ảnh mới nếu muốn thay đổi ảnh cũ</span>
                            </li>
                            <li>
                                <i class="fa-solid fa-check"></i>
                                <span>Cập nhật số chỗ trống khi có hủy đặt chỗ</span>
                            </li>
                            <li>
                                <i class="fa-solid fa-check"></i>
                                <span>Giá mới sẽ áp dụng ngay sau khi lưu</span>
                            </li>
                            <li>
                                <i class="fa-solid fa-check"></i>
                                <span>Nhấn "Hủy" để quay lại mà không lưu thay đổi</span>
                            </li>
                        </ul>
                    </div>
                </div>

            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/product/admin-product-form.js" asp-append-version="true"></script>
}
