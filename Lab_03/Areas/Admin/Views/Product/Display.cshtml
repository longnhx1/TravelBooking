@model Lab_03.Models.Product

@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/product/admin-product-display.css" asp-append-version="true" />
}

<div class="product-display-page">
    <!-- Page Header -->
    <header class="product-display-header">
        <div class="product-display-header__left">
            <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="product-display-header__back" title="Quay lại danh sách">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <nav class="product-display-header__breadcrumb">
                <a asp-area="Admin" asp-controller="Product" asp-action="Index">Quản lý Tour</a>
                <i class="fa-solid fa-chevron-right"></i>
                <span>@Model.Name</span>
            </nav>
        </div>
        <div class="product-display-header__actions">
            <a asp-area="Admin" asp-controller="Product" asp-action="Update" asp-route-id="@Model.Id" class="btn-secondary">
                <i class="fa-solid fa-pen-to-square"></i>
                <span>Chỉnh sửa</span>
            </a>
            <a asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@Model.Id" class="btn-danger">
                <i class="fa-solid fa-trash-can"></i>
                <span>Xóa</span>
            </a>
        </div>
    </header>

    <!-- Content Grid -->
    <div class="product-display__grid">

        <!-- Ảnh Tour -->
        <div class="product-display__image-card">
            <div class="product-image-wrapper">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name" class="product-image" id="productImage" />
                    <button type="button" class="image-zoom-btn" id="zoomImageBtn" title="Phóng to">
                        <i class="fa-solid fa-magnifying-glass-plus"></i>
                    </button>
                }
                else
                {
                    <div class="product-no-image">
                        <i class="fa-solid fa-image"></i>
                        <p>Chưa có ảnh đại diện</p>
                    </div>
                }
            </div>
        </div>

        <!-- Thông tin Tour -->
        <div class="product-display__info">

            <!-- Card: Tổng quan -->
            <div class="info-card">
                <div class="info-card__header">
                    <span class="info-card__badge">
                        <i class="fa-solid fa-location-dot"></i>
                        @(Model.Category?.Name ?? "Chưa phân loại")
                    </span>
                    <span class="info-card__id">ID: #@Model.Id</span>
                </div>
                <h1 class="info-card__title">@Model.Name</h1>
                <div class="info-card__price">
                    <span class="price-label">Giá / Người:</span>
                    <span class="price-value">@Model.Price.ToString("N0") ₫</span>
                </div>
            </div>

            <!-- Card: Thông tin chuyến đi -->
            <div class="info-card">
                <div class="info-card__section">
                    <h3 class="info-card__section-title">
                        <i class="fa-solid fa-circle-info"></i>
                        Thông tin chuyến đi
                    </h3>
                    <div class="tour-meta-grid">
                        <div class="tour-meta-item">
                            <span class="tour-meta-item__label">
                                <i class="fa-regular fa-clock"></i> Thời gian
                            </span>
                            <span class="tour-meta-item__value">
                                @(string.IsNullOrEmpty(Model.Duration) ? "Chưa cập nhật" : Model.Duration)
                            </span>
                        </div>
                        <div class="tour-meta-item">
                            <span class="tour-meta-item__label">
                                <i class="fa-solid fa-location-dot"></i> Nơi khởi hành
                            </span>
                            <span class="tour-meta-item__value">
                                @(string.IsNullOrEmpty(Model.DepartureLocation) ? "Chưa cập nhật" : Model.DepartureLocation)
                            </span>
                        </div>
                        <div class="tour-meta-item">
                            <span class="tour-meta-item__label">
                                <i class="fa-solid fa-calendar-day"></i> Ngày khởi hành
                            </span>
                            <span class="tour-meta-item__value">
                                @(Model.DepartureDate.HasValue
                                    ? Model.DepartureDate.Value.ToString("HH:mm – dd/MM/yyyy")
                                    : "Chưa cập nhật")
                            </span>
                        </div>
                        <div class="tour-meta-item">
                            <span class="tour-meta-item__label">
                                <i class="fa-solid fa-users"></i> Chỗ trống
                            </span>
                            <span class="tour-meta-item__value @(Model.AvailableSeats.HasValue && Model.AvailableSeats.Value == 0 ? "value--danger" : Model.AvailableSeats.HasValue && Model.AvailableSeats.Value <= 5 ? "value--warning" : "")">
                                @if (Model.AvailableSeats.HasValue)
                                {
                                    if (Model.AvailableSeats.Value == 0)
                                    {
                                        <i class="fa-solid fa-ban"></i> <text>Hết chỗ</text>
                                    }
                                    else
                                    {
                                        <text>@Model.AvailableSeats chỗ còn trống</text>
                                    }
                                }
                                else
                                {
                                    <text>Chưa cập nhật</text>
                                }
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card: Lịch trình & Mô tả -->
            <div class="info-card">
                <div class="info-card__section">
                    <h3 class="info-card__section-title">
                        <i class="fa-solid fa-align-left"></i>
                        Lịch trình & Mô tả
                    </h3>
                    <div class="info-card__description">
                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <p>@Model.Description</p>
                        }
                        else
                        {
                            <p class="text-muted">Chưa có lịch trình cho tour này.</p>
                        }
                    </div>
                </div>
            </div>

            <!-- Card: Thao tác nhanh -->
            <div class="info-card info-card--actions">
                <h3 class="info-card__section-title">
                    <i class="fa-solid fa-bolt"></i>
                    Thao tác nhanh
                </h3>
                <div class="quick-actions">
                    <a asp-area="Admin" asp-controller="Product" asp-action="Update" asp-route-id="@Model.Id" class="quick-action-btn">
                        <i class="fa-solid fa-pen-to-square"></i>
                        <span>Chỉnh sửa thông tin Tour</span>
                    </a>
                    <button type="button" class="quick-action-btn" id="copyLinkBtn"
                            data-url="@Url.Action("Display", "Product", new { area = "Admin", id = Model.Id })">
                        <i class="fa-solid fa-link"></i>
                        <span>Sao chép liên kết</span>
                    </button>
                    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="quick-action-btn">
                        <i class="fa-solid fa-list"></i>
                        <span>Xem danh sách Tour</span>
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Image Lightbox -->
<div class="lightbox" id="imageLightbox">
    <button type="button" class="lightbox__close" id="closeLightbox">
        <i class="fa-solid fa-xmark"></i>
    </button>
    <img src="@Model.ImageUrl" alt="@Model.Name" class="lightbox__image" />
</div>

@section Scripts {
    <script src="~/js/product/admin-product-display.js" asp-append-version="true"></script>
}
