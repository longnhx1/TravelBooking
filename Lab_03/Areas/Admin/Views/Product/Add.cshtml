@model Lab_03.Models.Product
@{
    ViewData["Title"] = "Thêm Sản Phẩm Mới";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-product-form.css" asp-append-version="true" />
}

<div class="product-form-page">
    <!-- Page Header -->
    <div class="product-form-header">
        <div class="product-form-header__left">
            <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="product-form-header__back">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div class="product-form-header__title">
                <h1>Thêm Sản Phẩm Mới</h1>
                <p>Điền thông tin chi tiết để tạo sản phẩm mới</p>
            </div>
        </div>
        <div class="product-form-header__actions">
            <button type="button" class="btn-secondary" id="btnReset">
                <i class="fa-solid fa-rotate-left"></i>
                <span>Làm mới</span>
            </button>
            <button type="submit" form="productForm" class="btn-primary">
                <i class="fa-solid fa-plus"></i>
                <span>Lưu Sản Phẩm</span>
            </button>
        </div>
    </div>

    <!-- Form Container -->
    <form asp-area="Admin" asp-action="Add" method="post" enctype="multipart/form-data" id="productForm" class="product-form">
        <div class="product-form__grid">
            <!-- Left Column - Main Info -->
            <div class="product-form__main">
                <!-- Basic Information Card -->
                <div class="form-card">
                    <div class="form-card__header">
                        <i class="fa-solid fa-box"></i>
                        <h2>Thông tin cơ bản</h2>
                    </div>
                    <div class="form-card__body">
                        <div class="form-group">
                            <label asp-for="Name" class="form-label">
                                Tên sản phẩm <span class="required">*</span>
                            </label>
                            <input asp-for="Name" class="form-input" placeholder="Nhập tên sản phẩm..." />
                            <span asp-validation-for="Name" class="form-error"></span>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="Price" class="form-label">
                                    Giá bán <span class="required">*</span>
                                </label>
                                <div class="input-with-suffix">
                                    <input asp-for="Price" type="number" class="form-input" placeholder="0" min="0" />
                                    <span class="input-suffix">VNĐ</span>
                                </div>
                                <span asp-validation-for="Price" class="form-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="CategoryId" class="form-label">
                                    Danh mục <span class="required">*</span>
                                </label>
                                <div class="select-wrapper">
                                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                                        <option value="">-- Chọn danh mục --</option>
                                    </select>
                                    <i class="fa-solid fa-chevron-down select-icon"></i>
                                </div>
                                <span asp-validation-for="CategoryId" class="form-error"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Description Card -->
                <div class="form-card">
                    <div class="form-card__header">
                        <i class="fa-solid fa-align-left"></i>
                        <h2>Mô tả sản phẩm</h2>
                    </div>
                    <div class="form-card__body">
                        <div class="form-group">
                            <label asp-for="Description" class="form-label">Mô tả chi tiết</label>
                            <textarea asp-for="Description" class="form-textarea" rows="6" placeholder="Nhập mô tả chi tiết về sản phẩm..."></textarea>
                            <span asp-validation-for="Description" class="form-error"></span>
                            <div class="form-hint">
                                <i class="fa-solid fa-circle-info"></i>
                                <span>Mô tả chi tiết giúp khách hàng hiểu rõ hơn về sản phẩm</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column - Image Upload -->
            <div class="product-form__sidebar">
                <div class="form-card">
                    <div class="form-card__header">
                        <i class="fa-solid fa-image"></i>
                        <h2>Hình ảnh sản phẩm</h2>
                    </div>
                    <div class="form-card__body">
                        <div class="image-upload" id="imageUpload">
                            <input type="file" name="imageUrl" id="imageInput" class="image-upload__input" accept="image/*" />

                            <!-- Upload placeholder -->
                            <div class="image-upload__placeholder" id="uploadPlaceholder">
                                <div class="image-upload__icon">
                                    <i class="fa-solid fa-cloud-arrow-up"></i>
                                </div>
                                <p class="image-upload__text">Kéo thả ảnh vào đây hoặc</p>
                                <label for="imageInput" class="image-upload__btn">
                                    <i class="fa-solid fa-folder-open"></i>
                                    <span>Chọn ảnh</span>
                                </label>
                                <p class="image-upload__hint">PNG, JPG, WEBP (tối đa 5MB)</p>
                            </div>

                            <!-- Image preview -->
                            <div class="image-upload__preview d-none" id="imagePreviewContainer">
                                <img id="imagePreview" src="#" alt="Ảnh xem trước" />
                                <div class="image-upload__overlay">
                                    <button type="button" class="image-upload__remove" id="removeImage">
                                        <i class="fa-solid fa-trash"></i>
                                        <span>Xóa ảnh</span>
                                    </button>
                                    <label for="imageInput" class="image-upload__change">
                                        <i class="fa-solid fa-arrows-rotate"></i>
                                        <span>Đổi ảnh</span>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tips Card -->
                <div class="form-card form-card--tips">
                    <div class="form-card__header">
                        <i class="fa-solid fa-lightbulb"></i>
                        <h2>Mẹo hay</h2>
                    </div>
                    <div class="form-card__body">
                        <ul class="tips-list">
                            <li>
                                <i class="fa-solid fa-check"></i>
                                <span>Sử dụng ảnh có độ phân giải cao</span>
                            </li>
                            <li>
                                <i class="fa-solid fa-check"></i>
                                <span>Đặt tên sản phẩm rõ ràng, dễ tìm kiếm</span>
                            </li>
                            <li>
                                <i class="fa-solid fa-check"></i>
                                <span>Mô tả đầy đủ thông số kỹ thuật</span>
                            </li>
                            <li>
                                <i class="fa-solid fa-check"></i>
                                <span>Chọn đúng danh mục để dễ quản lý</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/admin-product-form.js" asp-append-version="true"></script>
}
