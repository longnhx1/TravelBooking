<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Admin Dashboard – Quản lý Travel Booking" />
    <title>@ViewData["Title"] – Travel Booking Admin</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <!-- Stylesheets -->
    <link rel="stylesheet" href="~/css/admin-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />

    <!-- Page-specific styles -->
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="admin-body">

    <!-- =========== ADMIN HEADER =========== -->
    <header class="admin-header">
        <div class="admin-header__inner">
            <!-- Logo + Sidebar Toggle -->
            <div class="admin-header__left">
                <button class="admin-sidebar-toggle" id="sidebarToggleBtn" aria-label="Bật/tắt sidebar" aria-expanded="true">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <a href="/admin" class="admin-header__logo">
                    <i class="fa-solid fa-paper-plane"></i>
                    <span>Travel Admin</span>
                </a>
            </div>

            <!-- Admin actions -->
            <div class="admin-header__right">
                <div class="admin-header__search">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="search" placeholder="Tìm kiếm tour, đặt chỗ..." />
                </div>
                <button class="admin-header__action-btn" aria-label="Thông báo">
                    <i class="fa-solid fa-bell"></i>
                    <span class="admin-header__badge">3</span>
                </button>
                <button class="admin-header__action-btn" aria-label="Hồ sơ">
                    <i class="fa-solid fa-circle-user"></i>
                </button>
            </div>
        </div>
    </header>

    <!-- =========== MAIN LAYOUT =========== -->
    <div class="admin-layout">

        <!-- =========== SIDEBAR NAVIGATION =========== -->
        <aside class="admin-sidebar" id="adminSidebar" aria-label="Menu điều hướng">
            <nav class="admin-nav">
                <ul class="admin-nav__list">

                    <!-- Dashboard -->
                    <li class="admin-nav__item">
                        <a class="admin-nav__link" asp-area="Admin" asp-controller="Home" asp-action="Index">
                            <i class="fa-solid fa-house-chimney"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>

                    <!-- Tour Management -->
                    <li class="admin-nav__item">
                        <button class="admin-nav__link admin-nav__parent" data-submenu="products">
                            <i class="fa-solid fa-map-location-dot"></i>
                            <span>Quản lý Tour</span>
                            <i class="fa-solid fa-chevron-down admin-nav__chevron"></i>
                        </button>
                        <ul class="admin-nav__submenu" id="submenu-products" aria-hidden="true">
                            <li>
                                <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="admin-nav__sublink">
                                    <i class="fa-solid fa-list"></i> Danh sách Tour
                                </a>
                            </li>
                            <li>
                                <a asp-area="Admin" asp-controller="Product" asp-action="Add" class="admin-nav__sublink">
                                    <i class="fa-solid fa-plus"></i> Thêm Tour mới
                                </a>
                            </li>
                            <li>
                                <a href="/admin/categories" class="admin-nav__sublink">
                                    <i class="fa-solid fa-tags"></i> Điểm đến (Danh mục)
                                </a>
                            </li>
                        </ul>
                    </li>

                    <!-- Bookings Management -->
                    <li class="admin-nav__item">
                        <button class="admin-nav__link admin-nav__parent" data-submenu="orders">
                            <i class="fa-solid fa-calendar-check"></i>
                            <span>Đặt chỗ</span>
                            <i class="fa-solid fa-chevron-down admin-nav__chevron"></i>
                        </button>
                        <ul class="admin-nav__submenu" id="submenu-orders" aria-hidden="true">
                            <li><a href="/admin/orders" class="admin-nav__sublink"><i class="fa-solid fa-list-check"></i> Tất cả đặt chỗ</a></li>
                            <li><a href="/admin/orders?status=pending" class="admin-nav__sublink"><i class="fa-solid fa-clock"></i> Chờ xác nhận</a></li>
                            <li><a href="/admin/orders?status=confirmed" class="admin-nav__sublink"><i class="fa-solid fa-circle-check"></i> Đã xác nhận</a></li>
                            <li><a href="/admin/orders?status=completed" class="admin-nav__sublink"><i class="fa-solid fa-flag-checkered"></i> Hoàn thành</a></li>
                        </ul>
                    </li>

                    <!-- Customers -->
                    <li class="admin-nav__item">
                        <a href="/admin/customers" class="admin-nav__link">
                            <i class="fa-solid fa-users"></i>
                            <span>Khách hàng</span>
                        </a>
                    </li>

                    <!-- Reports -->
                    <li class="admin-nav__item">
                        <a href="/admin/reports" class="admin-nav__link">
                            <i class="fa-solid fa-chart-bar"></i>
                            <span>Báo cáo doanh thu</span>
                        </a>
                    </li>

                    <!-- Settings -->
                    <li class="admin-nav__item">
                        <button class="admin-nav__link admin-nav__parent" data-submenu="settings">
                            <i class="fa-solid fa-gear"></i>
                            <span>Cài đặt</span>
                            <i class="fa-solid fa-chevron-down admin-nav__chevron"></i>
                        </button>
                        <ul class="admin-nav__submenu" id="submenu-settings" aria-hidden="true">
                            <li><a href="/admin/settings/general" class="admin-nav__sublink">Cài đặt chung</a></li>
                            <li><a href="/admin/settings/payment" class="admin-nav__sublink">Thanh toán</a></li>
                            <li><a href="/admin/settings/users" class="admin-nav__sublink">Quản lý người dùng</a></li>
                        </ul>
                    </li>

                </ul>
            </nav>
        </aside>

        <!-- =========== MAIN CONTENT AREA =========== -->
        <main class="admin-main">
            <div class="admin-container">

                @* Success / Error TempData Toast *@
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert-toast alert-toast--success" id="tempDataToast">
                        <i class="fa-solid fa-circle-check"></i>
                        <span>@TempData["SuccessMessage"]</span>
                        <button type="button" class="alert-toast__close" onclick="this.parentElement.remove()">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert-toast alert-toast--error" id="tempDataToast">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span>@TempData["ErrorMessage"]</span>
                        <button type="button" class="alert-toast__close" onclick="this.parentElement.remove()">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </div>
                }

                @RenderBody()
            </div>
        </main>

    </div>

    <!-- Scripts -->
    <script src="~/js/admin-layout.js" asp-append-version="true"></script>
    <script src="~/js/admin-dashboard.js" asp-append-version="true"></script>

    <!-- Auto-dismiss TempData toast after 4s -->
    <script>
        (function () {
            var toast = document.getElementById('tempDataToast');
            if (toast) {
                setTimeout(function () {
                    toast.style.opacity = '0';
                    toast.style.transform = 'translateY(-8px)';
                    setTimeout(function () { toast.remove(); }, 300);
                }, 4000);
            }
        })();
    </script>

    <!-- Page-specific scripts -->
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
